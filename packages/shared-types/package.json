{
  "name": "@kok/shared-types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas": {
      "import": "./dist/schemas/index.js",
      "types": "./dist/schemas/index.d.ts"
    },
    "./trpc": {
      "import": "./dist/trpc/router.js",
      "types": "./dist/trpc/router.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3",
    "@trpc/server": "^11.17.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
